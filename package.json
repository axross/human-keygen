{
	"name": "human-keygen",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build && tsc --noEmit",
		"preview": "vite preview",
		"cf-typegen": "WRANGLER_WRITE_LOGS=false WRANGLER_SEND_METRICS=false wrangler types",
		"update-word-candidates": "node scripts/update-word-candidates.mjs",
		"format": "biome format --write .",
		"lint": "biome check .",
		"test": "vitest run",
		"test:e2e": "playwright test"
	},
	"dependencies": {
		"@tanstack/react-router": "1.170.10",
		"@tanstack/react-start": "1.168.18",
		"react": "19.2.6",
		"react-dom": "19.2.6"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.16",
		"@playwright/test": "1.60.0",
		"@tailwindcss/vite": "4.3.0",
		"@types/node": "25.9.1",
		"@types/react": "19.2.15",
		"@types/react-dom": "19.2.3",
		"@vitejs/plugin-react": "6.0.2",
		"tailwindcss": "4.3.0",
		"typescript": "5.9.3",
		"vite": "8.0.14",
		"vitest": "4.1.7",
		"wordlist-js": "2.0.0",
		"wrangler": "4.95.0"
	}
}
