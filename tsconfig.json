{
	"compilerOptions": {
		"allowImportingTsExtensions": true,
		"baseUrl": ".",
		"esModuleInterop": true,
		"jsx": "react-jsx",
		"lib": ["DOM", "DOM.Iterable", "ES2023"],
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"noEmit": true,
		"paths": {
			"@/*": ["./src/*"]
		},
		"skipLibCheck": true,
		"strict": true,
		"target": "ES2022",
		"types": ["node", "vite/client", "vitest/globals"]
	},
	"include": ["src", "e2e", "*.ts", "*.tsx"],
	"exclude": ["dist", "node_modules"]
}
